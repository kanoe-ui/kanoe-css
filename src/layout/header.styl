.header
  --background-color var(--color_white)
  --padding-horizontal var(--vertical-rhythm)
  --padding-vertical var(--vertical-rhythm)
  --border-color var(--color_white)
  --border-width var(--border-width--regular)
  align-content center
  align-items stretch
  background-color var(--background-color)
  display flex
  flex-direction row
  flex-wrap nowrap
  justify-content space-between
  padding var(--padding-vertical) var(--padding-horizontal) calc(var(--padding-vertical) - var(--border-width)) var(--padding-horizontal)
  border-bottom var(--border-width) solid var(--border-color)

  & > .grid_container
    align-content center
    align-items stretch
    background-color var(--background-color)
    display flex
    flex-direction row
    flex-wrap nowrap
    justify-content space-between
    padding 0

  &.has_border
    --border-color var(--color_gray)

  &.is_sticky
    position sticky
    top 0
    z-index 30

  [class*='header']
    order 1
    flex-grow 1

